# --- 鉴权（邮箱+密码注册/登录；JWT Cookie）---
JWT_SECRET=change-me-to-a-long-random-string

# --- 百炼（DashScope）OpenAI 兼容模式 ---
# 在「阿里云百炼 / 模型服务」控制台创建 API-Key（不要用 RAM 的 AccessKey）
# 二选一填写；可为 sk-sp- 等前缀。需要时用双引号包裹整段 Key，程序会自动去掉引号：
# DASHSCOPE_API_KEY="sk-sp-xxxxxxxxxxxxxxxx"
# OPENAI_API_KEY=sk-...
DASHSCOPE_API_KEY=sk-...

# 兼容模式 Base URL（不要漏 /compatible-mode/v1）
# 若已填 DASHSCOPE_API_KEY，可不写此项（程序会自动用百炼地址）
# 若只填了 OPENAI_API_KEY 且 Key 来自百炼，必须二选一：
#   OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
#   或 USE_DASHSCOPE_COMPAT=true
# OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# USE_DASHSCOPE_COMPAT=true

# 视觉多模态模型名：须与百炼「模型广场」一致；不填则百炼默认 qwen3-vl-flash
# 若报 model not supported，可依次尝试：qwen3-vl-flash、qwen-vl-max-latest、qwen-vl-plus-latest、qwen3-vl-plus
# OPENAI_VISION_MODEL=qwen3-vl-flash

# 若第一次「猫判定」接口报错不支持 JSON 模式，可加：
# CLASSIFY_JSON_FORMAT=false

# --- 服务 ---
PORT=8787
# CLIENT_ORIGIN=http://localhost:5173
# 生产环境且仅用 HTTP（如 http://公网IP）访问时须关闭 Secure Cookie，否则登录后接口仍 401：
# AUTH_COOKIE_SECURE=false
